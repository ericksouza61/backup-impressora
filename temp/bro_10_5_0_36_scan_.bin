lected="selected">A4</option><option value="2">Letter</option><option value="1">Legal/Folio</option></select></dd><dt>Duplex&#32;Scan</dt><dd><div><label class="radioSimple"><input type="radio" name="B20" value="0"  checked="checked" />Long&#32;edge</label><label class="radioSimple"><input type="radio" name="B20" value="1" />Short&#32;edge</label></div></dd><dt class="head">File&#32;Size</dt><dt class="subhead"><span>Color</span></dt><dd><select id="B22" name="B22" ><option value="3">Small</option><option value="2" selected="selected">Medium</option><option value="1">Large</option></select></dd><dt class="subhead"><span>Gray</span></dt><dd><select id="B23" name="B23" ><option value="3">Small</option><option value="2" selected="selected">Medium</option><option value="1">Large</option></select></dd></dl></div><div class="contentsButtons"><input type="button" value="Cancel" onclick="location.href=location.pathname+'?pageid=79'"/><input type="submit"  value="Submit" /></div></form></div></div></div></div><div id="mainFrameBottom"></div></div><div id="footerFrameContainer"><div id="copyright">Copyright(C) 2000-2012 Brother Industries, Ltd. All Rights Reserved.</div><div id="topBack"><a href="#">Top<img src="/common/images/ic_pt.gif" alt="Top" /></a></div></div></div></div></body></html>