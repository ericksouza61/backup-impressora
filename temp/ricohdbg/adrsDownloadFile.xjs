 function adrsHelp(file){
 	if (BaseForm) {
 		toHelp('..',file);
 	}
 	else {
 		location.reload(true);
 	}
 }
 
 function adrsListJump(){
 	if (BaseForm) {
 		if (buttonCheckFlag) { return; }
 		buttonCheckFlag = true;
 		if (MainForm.pageSpecifiedIn) {
 			MainForm.pageSpecifiedIn.value = FALSE;
 		}
 		if (MainForm.searchSpecifyModeIn) {
 			MainForm.searchSpecifyModeIn.value = "NONE";
 		}
 
 		utilSubmitForm(MainForm,ADRS_LIST);
 		utilPageSkipDisabled();
 	}
 	else {
 		location.reload(true);
 	}
 }
 
 function adrsUndo() {
 	var dest;
 	if (BaseForm) {
 		if (buttonCheckFlag) { return; }
 		buttonCheckFlag = true;
 		if (MainForm) {
 			if (MainForm.wayFrom) {
 				if (MainForm.wayFrom.value) {
 					dest = MainForm.wayFrom.value;
 
 					if (dest != EMPTY) {
 						utilExchangeValue(MainForm.wayFrom,MainForm.wayTo);
 						utilSubmitForm(MainForm,dest);
 						utilPageSkipDisabled();
 					}
 					else {
 						adrsListJump();
 					}
 				}
 				else {
 					adrsListJump();
 				}
 			}
 			else {
 				adrsListJump();
 			}
 		}
 		else {
 			adrsListJump();
 		}
 	}
 	else {
 		location.reload(true);
 	}
 }
 function adrsACLEditListUndo() {
 	var dest;
 	if (BaseForm) {
 		if (buttonCheckFlag) { return; }
 		buttonCheckFlag = true;
 		MainForm.searchSpecifyModeIn.value = "UNDO";
 		MainForm.inputSpecifyMode.value = "NONE";
 		utilSubmitForm(MainForm,ADRS_EDIT_LIST);
 		utilPageSkipDisabled();
 	}
 	else {
 		location.reload(true);
 	}
 }
 
 function inputPassword(kind){
 	var cnt = 0;
 	var skip = new skip_info();
 
 	if (BaseForm) {
 		if (CurrentMethod == ADRS_GET_USER) {
 			getSkipInfo(SKIP_USER_PASSWORD,kind,skip);
 		}
 		else {
 			getSkipInfo(SKIP_GROUP_PASSWORD,kind,skip);
 		}
 		MainForm.wayFrom.value = skip.from;
 		MainForm.wayTo.value = skip.to;
 		utilSubmitForm(MainForm,skip.via);
 		utilPageSkipDisabled();
 	}
 	else {
 		location.reload(true);
 	}
 }
 
 function deleteLimitCount(){
 	var cnt = 0;
 	var skip = new skip_info();
 
 	if (BaseForm) {
 		if (CurrentMethod == ADRS_GET_USER) {
 			getSkipInfo(SKIP_LIMITCOUNT_DELETE,EMPTY,skip);
 		}
 		MainForm.wayFrom.value = skip.from;
 		MainForm.wayTo.value = skip.to;
 		utilSubmitForm(MainForm,skip.via);
 		utilPageSkipDisabled();
 	}
 	else {
 		location.reload(true);
 	}
 }
 
 function adrsSetListPage(dest) {
 	if (BaseForm) {
 		if (dest == "top") {
 			MainForm.pageNumberIn.value = 0;
 		}
 		else if (dest == "pre") {
 			MainForm.pageNumberIn.value--;
 		}
 		else if (dest == "next") {
 			MainForm.pageNumberIn.value++;
 		}
 		else if (dest == "last") {
 			MainForm.pageNumberIn.value = 99999;
 		}
 		else{
 			MainForm.pageNumberIn.value = MainForm.pages.value;
 		}
 	}
 }
 
 function pageSkip() {
 	if (BaseForm) {
 		utilSubmitForm(MainForm,MainForm.wayTo.value);
 	}
 	else {
 		location.reload(true);
 	}
 }
 
 function adrsScriptStop(){
 	var aobj = document.getElementsByTagName('A');
 	for(var i=0; i<aobj.length ;i++){
 		ADSARRAYHREF[i] = aobj[i].getAttribute('href');
 		aobj[i].removeAttribute('href');
 	}
 }
 
 function adrsScriptRecover(){
 	var aobj = document.getElementsByTagName('A');
 	for(var i=0; i<ADSARRAYHREF.length ;i++){
 		aobj[i].setAttribute('href',ADSARRAYHREF[i]);
 	}
 }
 
 
 function DownloadFile(file) {
 	var key;
 
 	if (BaseForm) {
 		if(MainForm.mainteKeywk){
 			if(MainForm.mainteKeywk.value != EMPTY){
 				key = base64encode(MainForm.mainteKeywk.value);
 				MainForm.mainteKeywk.value = EMPTY;
 				file = file + "?key=" + key;
 			}
 		}
 		location.href = "adrsFileDownload.cgi/" + file;
 	}
 	else {
 		location.reload(true);
 	}
 }
 
 function Upload(kind) {
 
 	if (BaseForm) {
 		MainForm.kind.value = kind;
 
 		if(MainForm.mainteKeywk){
 			if(MainForm.mainteKeywk.value != EMPTY){
 				MainForm.mainteKey.value = base64encode(MainForm.mainteKeywk.value);
 				MainForm.mainteKeywk.value = EMPTY;
 			}
 		}
 
 		utilSubmitForm(MainForm,ADRS_UPLOAD_FILE);
 		utilPageSkipDisabled();
 	}
 	else {
 		location.reload(true);
 	}
 }
 
 