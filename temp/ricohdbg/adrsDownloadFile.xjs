 	obj.via.marker	= new part_info(EMPTY,	EMPTY);
 	obj.via.query	= new part_info(EMPTY,	"?inputSpecifyModeIn=WRITE");
 	obj.to.cgi		= new part_info(EMPTY,	ADRS_LIST);
