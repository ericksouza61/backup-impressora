 function part_info(key,value) {
	this.key = key;
	this.value = value;
 }
 <!-- cig,marker,queryé═part_infoé┼éÓé╗é╠özŚ±é┼éÓéµéóüBkeyé╔éµéķÅĻŹćĢ¬é»é¬ĢsŚvé╚ÅĻŹćé═æOÄęüAé╗éżé┼é╚éóÅĻŹćé═īŃÄęüB -->
 function url_parts() {
	this.cgi = EMPTY;
	this.marker = EMPTY;
	this.query = EMPTY;
 }
 function skip_list() {
	this.skipname;
	this.from = new url_parts();
	this.via = new url_parts();
	this.to = new url_parts();
 }
 function skip_info() {
 	this.from = EMPTY;
 	this.via = EMPTY;
 	this.to = EMPTY;
 }
 
 var SkipList = makeSkipList();
 function makeSkipList() {
 	var List = new Array();
 	var size = 0;
 	var obj;
 
 	obj				= new skip_list();
 	obj.skipname	= SKIP_USER_SET;
 	obj.from.cgi	= new part_info(EMPTY,	ADRS_GET_USER);
 	obj.from.marker	= new part_info(EMPTY,	EMPTY);
